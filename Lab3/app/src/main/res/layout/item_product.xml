<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="8dp"
    android:layout_marginVertical="6dp"
    app:cardElevation="3dp"
    app:cardCornerRadius="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:background="#A6FFFFFF">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="top">

            <TextView
                android:id="@+id/tvProductName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Назва товару"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/text_dark" />

            <ImageView
                android:id="@+id/btnToggleFavorite"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@android:drawable/btn_star_big_off"
                android:contentDescription="Toggle Favorite"
                android:layout_marginStart="8dp"
                app:tint="@color/primary_teal" />

        </LinearLayout>

        <TextView
            android:id="@+id/tvProductCategory"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="Категорія"
            android:textSize="12sp"
            android:textStyle="italic"
            android:textColor="@color/accent_cyan" />

        <TextView
            android:id="@+id/tvProductDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Опис товару..."
            android:textSize="14sp"
            android:textColor="@color/text_muted" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="16dp">

            <TextView
                android:id="@+id/tvProductPrice"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="0.00 грн"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/primary_teal" />

            <Button
                android:id="@+id/btnAddToCart"
                android:layout_width="wrap_content"
                android:layout_height="38dp"
                android:text="У кошик"
                android:textSize="12sp"
                android:paddingHorizontal="16dp"
                android:paddingVertical="0dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:backgroundTint="@color/primary_teal"
                android:textColor="@color/white" />

            <Button
                android:id="@+id/btnRemoveFromCart"
                android:layout_width="wrap_content"
                android:layout_height="38dp"
                android:text="Видалити"
                android:textSize="12sp"
                android:paddingHorizontal="16dp"
                android:paddingVertical="0dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:backgroundTint="@android:color/holo_red_dark"
                android:textColor="@color/white"
                android:visibility="gone"
                android:layout_marginStart="8dp" />

        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>
