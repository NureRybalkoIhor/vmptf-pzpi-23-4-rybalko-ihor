<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="8dp"
    android:layout_marginVertical="6dp"
    app:cardElevation="3dp"
    app:cardCornerRadius="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:background="#A6FFFFFF">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <TextView
                android:id="@+id/tvAdminOrderId"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Замовлення #-"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="@color/text_dark" />

            <TextView
                android:id="@+id/tvAdminOrderDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="01.01.2026"
                android:textSize="12sp"
                android:textColor="@color/text_muted" />

        </LinearLayout>

        <TextView
            android:id="@+id/tvAdminOrderUser"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Покупець: -"
            android:textSize="13sp"
            android:textColor="@color/text_dark"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/tvAdminOrderDelivery"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Доставка: -"
            android:textSize="13sp"
            android:textColor="@color/text_muted"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/tvAdminOrderItems"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Товари..."
            android:textSize="14sp"
            android:textColor="@color/text_muted"
            android:layout_marginBottom="12dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tvAdminOrderTotal"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Сума: 0.00 грн"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/primary_teal" />

            <Button
                android:id="@+id/btnChangeStatus"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="Змінити статус"
                android:textSize="11sp"
                android:paddingHorizontal="12dp"
                android:paddingVertical="0dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:backgroundTint="@color/primary_teal"
                android:textColor="@color/white"
                android:layout_marginEnd="8dp" />

            <TextView
                android:id="@+id/tvAdminOrderStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Очікує"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="@color/accent_cyan"
                android:paddingHorizontal="8dp"
                android:paddingVertical="4dp"
                android:background="@color/primary_teal_light" />

        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>
