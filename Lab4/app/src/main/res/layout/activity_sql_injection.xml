<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F0F8FF"
    android:padding="16dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="SQL Injection Sandbox"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="#008080"
        android:layout_marginBottom="16dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Search Client by Email"
        android:textSize="12sp"
        android:textColor="#888888"
        android:layout_marginBottom="4dp" />

    <EditText
        android:id="@+id/etEmailSearch"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="#FFFFFF"
        android:paddingLeft="12dp"
        android:hint="user@store.com' OR '1'='1"
        android:textColor="#333333"
        android:textSize="14sp"
        android:layout_marginBottom="16dp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnUnsafeQuery"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="Run Unsafe Mockup Query"
        android:textColor="#FFFFFF"
        android:backgroundTint="#D9534F"
        android:layout_marginBottom="8dp"
        android:insetTop="0dp"
        android:insetBottom="0dp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSafeExposed"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="Run Safe Exposed Query"
        android:textColor="#FFFFFF"
        android:backgroundTint="#008080"
        android:layout_marginBottom="8dp"
        android:insetTop="0dp"
        android:insetBottom="0dp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSafeJdbc"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="Run Safe JDBC PreparedStatement"
        android:textColor="#FFFFFF"
        android:backgroundTint="#008080"
        android:layout_marginBottom="16dp"
        android:insetTop="0dp"
        android:insetBottom="0dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Results Log"
        android:textSize="14sp"
        android:textStyle="bold"
        android:textColor="#008080"
        android:layout_marginBottom="8dp" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#FFFFFF"
        android:padding="12dp">

        <TextView
            android:id="@+id/tvSqlLogs"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Enter text and click run to inspect query outputs..."
            android:textColor="#333333"
            android:textSize="14sp"
            android:fontFamily="monospace" />

    </ScrollView>

</LinearLayout>
